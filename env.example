OPENAI_API_KEY=""
TAVILY_API_KEY=""

# ── LLM Models ────────────────────────────────────────────────
# Main chat / reasoning model
LLM_MODEL=gpt-4o
# Main model used by Graphiti during episode ingestion.
# This is the heavy extraction path for documents, so a fast mini model is recommended.
GRAPHITI_MODEL=gpt-4o-mini
# Model used by Graphiti for internal entity extraction & deduplication.
# High-volume during ingestion — keep this fast (mini is recommended).
GRAPHITI_SMALL_MODEL=gpt-4o-mini

# ── RAG Ingestion Tuning ──────────────────────────────────────
# Characters per chunk fed to Graphiti add_episode.
# Graphiti is designed for conversational turns (~500–3000 chars).
# Smaller = faster LLM calls + better extraction; larger = fewer chunks.
RAG_CHUNK_SIZE=2500
RAG_CHUNK_OVERLAP=200

# Parallel chunks in-flight during document ingest.
# Higher values improve throughput until the upstream LLM starts rate limiting.
# Keep this modest for Graphiti because each add_episode can fan out internally.
RAG_INGEST_CONCURRENCY=2

# Minimum spacing between chunk upload attempts across a single document ingest.
# Helps smooth burst traffic before the provider starts returning 429s.
RAG_INGEST_ATTEMPT_SPACING_SECONDS=0.75

# After the first 429, fall back to one chunk upload at a time for that document.
RAG_INGEST_SERIALIZE_ON_RATE_LIMIT=true

# Graphiti's internal async semaphore.
# Lower this when add_episode fan-out is causing provider throttling.
GRAPHITI_MAX_COROUTINES=6

# Number of recent episodes to pass back into sequential add_episode calls.
# Lower values keep prompts small and help prevent latency from growing over long documents.
GRAPHITI_PREVIOUS_EPISODE_WINDOW=2

# Number of document chunks to send through Graphiti's bulk episode API at once.
# Bulk mode is much faster for large uploads than one add_episode call per chunk.
GRAPHITI_BULK_INGEST_BATCH_SIZE=8

# Character budget per Graphiti bulk ingest request.
# Keeps bulk batches from growing so large that dedupe/extraction latency spikes.
GRAPHITI_BULK_MAX_BATCH_CHARS=10000

# ── PDF Extraction ────────────────────────────────────────────
# auto = use pypdf for text PDFs, Mistral OCR for scanned ones
# always = always use Mistral OCR (requires MISTRAL_API_KEY)
# never  = always use pypdf
PDF_OCR_MODE=auto
